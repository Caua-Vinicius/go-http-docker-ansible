{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "title": "http-server-projeto-korp",
  "uid": "korp-dashboard",
  "timezone": "browser",
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "title": "Disponibilidade do serviço",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-korp" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-korp" },
          "expr": "up{job=\"http-server-projeto-korp\"}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red" },
                "1": { "text": "UP", "color": "green" }
              }
            }
          ]
        }
      }
    },
    {
      "id": 2,
      "title": "Volume de requisições por segundo",
      "type": "timeseries",
      "gridPos": { "x": 6, "y": 0, "w": 18, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-korp" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-korp" },
          "expr": "rate(http_requests_total[1m])",
          "legendFormat": "{{method}} {{endpoint}} {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Total de requisições",
      "type": "stat",
      "gridPos": { "x": 0, "y": 4, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-korp" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-korp" },
          "expr": "sum(http_requests_total)",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      }
    }
  ]
}
